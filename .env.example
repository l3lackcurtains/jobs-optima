# ================================================
# MongoDB Database
# ================================================
MONGODB_URI=mongodb://localhost:27017/resume-builder
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/resume-builder

# ================================================
# Authentication & Security
# ================================================
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your-nextauth-secret-here  # Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here            # Generate: openssl rand -base64 32
JWT_EXPIRATION=7d

# ================================================
# API Configuration
# ================================================
# Internal URL used by Next.js server to reach the backend (SSR, proxy rewrites, NextAuth).
# In Docker: http://api:8888/api — in local dev without Docker: http://localhost:8888/api
INTERNAL_API_URL=http://localhost:8888/api
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:4000

# ================================================
# AI Provider Configuration
# ================================================
# Provider: gemini | openai | anthropic  (default: gemini)
AI_PROVIDER=gemini

# API key for the selected provider:
#   gemini    → https://aistudio.google.com/apikey
#   openai    → https://platform.openai.com/api-keys
#   anthropic → https://console.anthropic.com/settings/keys
AI_API_KEY=

# Model to use (optional — defaults per provider are listed below):
#   gemini    → gemini-2.5-flash
#   openai    → gpt-4o
#   anthropic → claude-sonnet-4-5
# AI_MODEL=gemini-2.5-flash

# Daily AI request limit per user (default: 20). Set higher for trusted deployments.
# AI_DAILY_LIMIT=20


# ================================================
# Redis Configuration (Upstash)
# ================================================
# Get your Redis URL from https://upstash.com
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# ================================================
# Application Ports
# ================================================
# Leave empty for Docker/Dokploy deployments
WEB_PORT=4000
API_PORT=8888

# ================================================
# Billing — Polar (optional, leave blank to disable)
# ================================================
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_ENVIRONMENT=sandbox
# Required when billing is enabled — URL to redirect after successful checkout
POLAR_SUCCESS_URL=https://your-domain.com/dashboard?upgraded=1

# ================================================
# Chrome Extension Build (set in apps/extension/.env)
# ================================================
# VITE_API_URL=https://your-api-domain.com/api
# VITE_WEB_URL=https://your-frontend-domain.com

# ================================================
# Environment
# ================================================
NODE_ENV=development