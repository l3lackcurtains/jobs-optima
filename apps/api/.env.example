# Application
NODE_ENV=development
PORT=8888

# MongoDB
MONGODB_URI=mongodb://localhost:27017/resume-builder

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=7d

# Platform AI key — used for the hosted Pro tier (managed Gemini Flash)
# and for system-level tasks like job-scanner relevance scoring.
# Get one from https://aistudio.google.com/apikey
PLATFORM_GEMINI_API_KEY=your-platform-gemini-key-here

# Redis (Upstash)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# CORS
CORS_ORIGIN=http://localhost:4000

# Polar.sh billing (https://polar.sh) — OPTIONAL.
# Leave unset to run as a free / OSS-only instance. When all four are set,
# the Pro tier ($5/mo, 500 ops) is enabled. See docs/BILLING.md.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_ENVIRONMENT=sandbox          # 'sandbox' | 'production'
POLAR_SUCCESS_URL=https://jobsoptima.com/dashboard?upgraded=1

# Optional outbound proxy for the job scanner.
# Job sites (LinkedIn, Indeed) often block datacenter IPs. If you're running
# on cloud and seeing scan failures, route through a residential or rotating
# proxy. Compatible with BrightData, Oxylabs, Smartproxy, ScraperAPI (proxy
# mode), Webshare, or any plain HTTP proxy. Leave unset for direct connection
# (works fine on residential IPs / self-host). See docs/SCRAPING.md.
SCRAPING_PROXY_SERVER=             # e.g. http://brd.superproxy.io:22225
SCRAPING_PROXY_USERNAME=
SCRAPING_PROXY_PASSWORD=
SCRAPING_PROXY_BYPASS=             # comma-separated hosts to skip the proxy
