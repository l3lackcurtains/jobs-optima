{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "extension:0.0.2",
  "sourceRoot": "apps/extension/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "apps/extension"
      },
      "outputs": ["{projectRoot}/.output"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "apps/extension"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf .output",
        "cwd": "apps/extension"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/extension"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run typecheck",
        "cwd": "apps/extension"
      }
    }
  },
  "tags": ["scope:extension", "type:app"]
}
