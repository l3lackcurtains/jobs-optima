# ================================================
# REQUIRED: MongoDB Atlas Connection
# ================================================
MONGODB_URI=mongodb+srv://<db_username>:<password>@cluster0.example.mongodb.net/resume-builder

# ================================================
# REQUIRED: Security Keys
# ================================================
NEXTAUTH_URL=https://your-frontend-domain.com
NEXTAUTH_SECRET=your-secret-here  # Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here  # Generate with: openssl rand -base64 32
JWT_EXPIRATION=7d

# ================================================
# REQUIRED: API Configuration
# ================================================
# Internal URL used by the Next.js server to reach the backend.
# Browser traffic is proxied through Next.js — the backend is never
# called directly from the browser and does NOT need a public domain.
# In Dokploy with docker-compose, use the service name as the hostname.
INTERNAL_API_URL=http://api:8888/api
# CORS origins — set to your frontend domain only
CORS_ORIGIN=https://your-frontend-domain.com

# ================================================
# OPTIONAL: Port Configuration
# ================================================
# Leave empty for Dokploy (it handles ports automatically via Traefik)
WEB_PORT=
API_PORT=

# ================================================
# OPTIONAL: AI Configuration (server default)
# ================================================
# Users can bring their own key in-app; these are fallbacks.
AI_PROVIDER=gemini
AI_API_KEY=your-gemini-api-key-here
# Optionally override the model (default: gemini-2.5-flash)
# AI_MODEL=gemini-2.5-flash
# Daily AI request limit per user — server default (default: 20)
# AI_DAILY_LIMIT=50
# Job scanner scoring key (optional — falls back to AI_API_KEY if unset)
# PLATFORM_GEMINI_API_KEY=your-platform-key-here

# ================================================
# REQUIRED: Redis
# ================================================
# Format: redis://[username]:[password]@[host]:[port]
# Or for TLS: rediss://[username]:[password]@[host]:[port]
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:6379

# ================================================
# OPTIONAL: Environment
# ================================================
NODE_ENV=production
