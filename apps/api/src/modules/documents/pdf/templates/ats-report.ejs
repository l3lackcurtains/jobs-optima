<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ATS Analysis Report</title>
    <style>
      body {
        font-family: "Open Sans", sans-serif;
        font-size: 14px;
        line-height: 1.6;
        margin: 20px;
        color: #333;
        background-color: #fff;
      }

      h1, h2, h3 {
        margin: 0 0 12px;
        font-weight: bold;
      }

      h1 {
        font-size: 28px;
        color: #2c3e50;
      }

      h2 {
        font-size: 20px;
        color: #34495e;
        border-bottom: 2px solid #ecf0f1;
        padding-bottom: 8px;
        margin-top: 24px;
      }

      .summary-box {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 20px;
        margin: 20px 0;
      }

      .metric {
        display: flex;
        justify-content: space-between;
        margin: 8px 0;
      }

      .metric-label {
        font-weight: bold;
      }

      .metric-value {
        color: #007bff;
      }

      .percentage {
        font-size: 36px;
        font-weight: bold;
        text-align: center;
        margin: 20px 0;
      }

      .good { color: #28a745; }
      .warning { color: #ffc107; }
      .danger { color: #dc3545; }

      .keyword-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 12px 0;
      }

      .keyword {
        background-color: #e9ecef;
        padding: 4px 12px;
        border-radius: 16px;
        font-size: 12px;
      }

      .matched {
        background-color: #d4edda;
        color: #155724;
      }

      .unmatched {
        background-color: #f8d7da;
        color: #721c24;
      }

      .section {
        margin-bottom: 24px;
      }

      .job-description {
        background-color: #f8f9fa;
        padding: 16px;
        border-radius: 8px;
        margin: 12px 0;
        font-size: 13px;
        line-height: 1.6;
      }
    </style>
  </head>
  <body>
    <h1>ATS Analysis Report</h1>
    <p><strong>Resume:</strong> <%= resume.title %></p>
    <p><strong>Generated:</strong> <%= new Date().toLocaleDateString() %></p>

    <div class="summary-box">
      <h2>Overall Match Score</h2>
      <div class="percentage <%= matchPercentage >= 80 ? 'good' : matchPercentage >= 60 ? 'warning' : 'danger' %>">
        <%= matchPercentage %>%
      </div>
      <div class="metric">
        <span class="metric-label">Total Keywords:</span>
        <span class="metric-value"><%= keywords.length %></span>
      </div>
      <div class="metric">
        <span class="metric-label">Matched Keywords:</span>
        <span class="metric-value"><%= matchedKeywords.length %></span>
      </div>
      <div class="metric">
        <span class="metric-label">Missing Keywords:</span>
        <span class="metric-value"><%= unmatchedKeywords.length %></span>
      </div>
    </div>

    <div class="section">
      <h2>Job Description</h2>
      <div class="job-description">
        <%= jobDescription %>
      </div>
    </div>

    <div class="section">
      <h2>All Keywords</h2>
      <div class="keyword-list">
        <% keywords.forEach(function(keyword) { %>
        <span class="keyword"><%= keyword %></span>
        <% }); %>
      </div>
    </div>

    <div class="section">
      <h2>Matched Keywords (<%= matchedKeywords.length %>)</h2>
      <div class="keyword-list">
        <% matchedKeywords.forEach(function(keyword) { %>
        <span class="keyword matched"><%= keyword %></span>
        <% }); %>
      </div>
    </div>

    <div class="section">
      <h2>Missing Keywords (<%= unmatchedKeywords.length %>)</h2>
      <div class="keyword-list">
        <% unmatchedKeywords.forEach(function(keyword) { %>
        <span class="keyword unmatched"><%= keyword %></span>
        <% }); %>
      </div>
    </div>

    <div class="section">
      <h2>Recommendations</h2>
      <% if (unmatchedKeywords.length > 0) { %>
      <p>Consider incorporating these missing keywords where relevant:</p>
      <ul>
        <% unmatchedKeywords.slice(0, 5).forEach(function(keyword) { %>
        <li><%= keyword %></li>
        <% }); %>
      </ul>
      <% } else { %>
      <p>Great job! Your resume contains all major keywords from the job description.</p>
      <% } %>
    </div>
  </body>
</html>